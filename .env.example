# =============================================
#  CONFIGURAÇÕES DO ASAAS
# =============================================

# Ambiente: 'sandbox' ou 'production'
ASAAS_ENV=sandbox

# Chave da API (encontre em Minha Conta > Integrações)
# Sandbox:   https://sandbox.asaas.com
# Produção:  https://app.asaas.com
ASAAS_KEY=$aas_SuaChaveAqui

# =============================================
#  SERVIDOR
# =============================================
PORT=3000

# Origem permitida para o CORS (URL do seu frontend)
# Exemplo: http://localhost:5500 ou https://seusite.com.br
FRONTEND_URL=http://localhost:5500

# =============================================
#  WEBHOOK & TRACKING
# =============================================

# Token de segurança para o Webhook do Asaas (Crie o seu)
WEBHOOK_TOKEN=

# Meta Conversions API (CAPI)
META_PIXEL_ID=
META_ACCESS_TOKEN=

# Código de teste da Meta (Deixe VAZIO em produção para contar vendas reais)
META_TEST_CODE=
